# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zorvyn_finance"
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zorvyn_finance_test"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
